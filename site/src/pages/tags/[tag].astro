---
import Base from "~/layouts/Base.astro";
import ReportCard from "~/components/ReportCard.astro";
import JsonLd from "~/components/JsonLd.astro";
import { getReports, getTagsDoc, getTagLabels, absoluteUrl, SITE } from "~/lib/data";

export async function getStaticPaths() {
  const tagsDoc = getTagsDoc();
  const all = new Set<string>();
  for (const ts of Object.values(tagsDoc.entries)) for (const t of ts) all.add(t);
  return Array.from(all).map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const labels = getTagLabels();
const label = labels[tag] ?? tag;
const reports = getReports();
const tagsDoc = getTagsDoc();
const base = import.meta.env.BASE_URL;

const items = reports
  .filter((r) => (tagsDoc.entries[r.slug] ?? []).includes(tag))
  .sort((a, b) => (b.stars ?? 0) - (a.stars ?? 0));

const samples = items.slice(0, 3).map((r) => r.title).filter(Boolean).join("、");
const description = samples
  ? `${label} 主题 GitHub 仓库深度分析（共 ${items.length} 篇）· 涵盖 ${samples} 等。`
  : `${label} 主题 GitHub 仓库深度分析（共 ${items.length} 篇）。`;

const tagUrl = absoluteUrl(`/tags/${tag}`);
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `#${label} · ${SITE.title}`,
  description,
  url: tagUrl,
  inLanguage: "zh-CN",
  isPartOf: { "@id": `${absoluteUrl("/")}#website` },
  about: { "@type": "Thing", name: label },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: items.length,
    itemListElement: items.slice(0, 10).map((r, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: absoluteUrl(`/reports/${r.slug}`),
      name: r.title ?? r.slug,
    })),
  },
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "首页", item: absoluteUrl("/") },
    { "@type": "ListItem", position: 2, name: "标签", item: absoluteUrl("/tags") },
    { "@type": "ListItem", position: 3, name: label, item: tagUrl },
  ],
};
---

<Base
  title={`#${label}`}
  description={description}
  canonicalPath={`/tags/${tag}`}
  keywords={[label, "GitHub", "开源项目分析"]}
>
  <Fragment slot="head">
    <JsonLd data={collectionSchema} />
    <JsonLd data={breadcrumbSchema} />
  </Fragment>
  <section class="max-w-6xl mx-auto px-4 py-10">
    <nav class="text-sm text-zinc-500 mb-4">
      <a href={`${base}/`} class="hover:text-brand">首页</a>
      <span class="mx-1">/</span>
      <a href={`${base}/tags`} class="hover:text-brand">标签</a>
      <span class="mx-1">/</span>
      <span class="text-zinc-700">{label}</span>
    </nav>
    <h1 class="text-2xl font-bold">
      #{label} <span class="text-zinc-400 text-base font-normal">{items.length} 篇</span>
    </h1>
    <p class="text-xs text-zinc-400 mb-6 font-mono">tag: {tag}</p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {items.map((r) => <ReportCard report={r} compact />)}
    </div>
  </section>
</Base>
