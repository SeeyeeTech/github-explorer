---
import "~/styles/global.css";
import { SITE } from "~/lib/data";

interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.title}` : SITE.title;
const desc = description ?? SITE.description;
const base = import.meta.env.BASE_URL;
const nav = [
  { href: `${base}/`, label: "首页" },
  { href: `${base}/reports`, label: "全部报告" },
  { href: `${base}/tags`, label: "标签" },
  { href: `${base}/trending`, label: "Trending" },
  { href: `${base}/starred`, label: "大牛 Star" },
  { href: `${base}/submit`, label: "提交仓库" },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <link rel="icon" href={`${base}/favicon.svg`} />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-zinc-200 bg-white sticky top-0 z-30 backdrop-blur">
      <div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap items-center gap-4">
        <a href={`${base}/`} class="flex items-center gap-2 font-semibold text-lg shrink-0">
          <span class="inline-block w-2 h-6 bg-brand rounded-sm"></span>
          <span>{SITE.title}</span>
        </a>
        <nav class="flex-1 flex flex-wrap items-center gap-1 text-sm">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class="px-3 py-1.5 rounded hover:bg-zinc-100 text-zinc-700 hover:text-zinc-900"
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <a
          href={SITE.repoUrl}
          target="_blank"
          rel="noopener"
          class="text-sm text-zinc-500 hover:text-zinc-900"
          aria-label="GitHub 仓库"
        >
          GitHub →
        </a>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-16 py-8 border-t border-zinc-200 text-sm text-zinc-500">
      <div class="max-w-6xl mx-auto px-4 flex flex-wrap gap-4 justify-between">
        <div>
          © {new Date().getFullYear()} {SITE.title} · 由
          <a class="underline" href={SITE.repoUrl} target="_blank" rel="noopener"
            >AustinXT/github-explorer</a
          > 驱动
        </div>
        <div>
          <a class="hover:text-zinc-900" href={`${base}/submit`}>提交一个仓库 →</a>
        </div>
      </div>
    </footer>
  </body>
</html>
