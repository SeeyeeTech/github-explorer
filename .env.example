# 复制为 .env.local 后填入真实值（.env.local 已在 .gitignore 内）。
# GitHub Actions 需在仓库 Settings → Secrets and variables → Actions 配置同名 secrets。

# ────────────────────────────────────────
# 推理后端：MiniMax 的 Anthropic 兼容端点
# ────────────────────────────────────────
# 到 https://platform.minimaxi.com/docs/token-plan/claude-code 申请 token plan，
# 拿到的 token 在 CI 里会被映射成 ANTHROPIC_AUTH_TOKEN（不是 ANTHROPIC_API_KEY）
MINIMAX_API_KEY=

# BASE URL 已写死在 src/scripts/run_skill.sh 里：
#   国内版（默认）：https://api.minimaxi.com/anthropic
#   国际版：       https://api.minimax.io/anthropic
# 切换方式：编辑 src/scripts/run_skill.sh 顶部 MINIMAX_ENDPOINT 常量，
# 或在 CI 里设置 MINIMAX_BASE_URL_OVERRIDE 临时覆盖
MINIMAX_BASE_URL_OVERRIDE=

# ────────────────────────────────────────
# 应急降级（可选，正常运行时不要配）
# ────────────────────────────────────────
# 只有 Minimax 不可用或某些 skill 兼容性问题时才配。
# 配上后用 workflow_dispatch 输入 force_backend=anthropic 才会启用。
ANTHROPIC_API_KEY=

# ────────────────────────────────────────
# 微信公众号草稿箱（md2wechat skill 必需）
# ────────────────────────────────────────
WECHAT_APPID=
WECHAT_APPSECRET=

# 公众号 API 走自建反代（用于固定出口 IP 命中白名单的 CI 场景）
# 留空 = 本地直连 https://api.weixin.qq.com（前提：本地 IP 已在白名单内）
# 反代部署见 docs/wechat-proxy.md（待补）
WECHAT_API_BASE=
WECHAT_PROXY_TOKEN=
# 公众号后台「IP 白名单」必须包含反代服务器的公网 IP（默认实现：47.113.202.7）
# 注意：白名单为「显式准入」机制，留空时所有调用都会返回 errcode 40164

# ────────────────────────────────────────
# GitHub API
# ────────────────────────────────────────
# 本地用 gh auth login 即可；CI 默认用 GITHUB_TOKEN，无需单独配
GH_TOKEN=

# ────────────────────────────────────────
# 可选：完成通知（飞书机器人 / 邮件等）
# ────────────────────────────────────────
NOTIFY_WEBHOOK_URL=


CNBLOGS_BLOGAPP=your-blog-id
CNBLOGS_USERNAME=your-login-name
CNBLOGS_TOKEN=your-metaweblog-token
# 下面两行可选
# CNBLOGS_RPC_URL=https://rpc.cnblogs.com/metaweblog/your-blog-id   # 默认就是这个，一般不用填
# CNBLOGS_CATEGORIES=[随笔分类]开源                                  # 逗号分隔
