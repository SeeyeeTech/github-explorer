---
import "~/styles/global.css";
import { SITE, absoluteUrl } from "~/lib/data";
import SearchBox from "~/components/SearchBox.astro";
import JsonLd from "~/components/JsonLd.astro";
import WeChatFollow from "~/components/WeChatFollow.astro";

interface Props {
  title?: string;
  description?: string;
  // 默认整个 main 不进 Pagefind 索引；报告详情页传 false 让 [data-pagefind-body] 圈定的正文被索引
  pagefindIgnore?: boolean;
  // SEO / 社交分享
  ogImage?: string; // 绝对 URL；不传则用默认图
  ogType?: "website" | "article" | "profile";
  canonicalPath?: string; // 默认取 Astro.url.pathname
  keywords?: string[]; // 与 SITE.keywords 合并去重
  noindex?: boolean;
  publishedTime?: string; // ISO 时间字符串（仅 article 类型生效）
  modifiedTime?: string;
  articleTags?: string[];
}
const {
  title,
  description,
  pagefindIgnore = true,
  ogImage,
  ogType = "website",
  canonicalPath,
  keywords,
  noindex = false,
  publishedTime,
  modifiedTime,
  articleTags,
} = Astro.props;

const fullTitle = title ? `${title} · ${SITE.title}` : SITE.title;
const desc = description ?? SITE.description;
const base = import.meta.env.BASE_URL;

// Astro.url.pathname 含 base 子路径；canonicalPath 应是"去 base 后"的应用路径
const baseStripped = base.replace(/\/$/, "");
const currentPath =
  canonicalPath ??
  (Astro.url.pathname.startsWith(baseStripped)
    ? Astro.url.pathname.slice(baseStripped.length) || "/"
    : Astro.url.pathname || "/");
const canonical = absoluteUrl(currentPath);
const ogImg = ogImage ?? absoluteUrl(SITE.defaultOgImage);
const rssHref = absoluteUrl("/rss.xml");
const jsonFeedHref = absoluteUrl("/feed.json");

const mergedKeywords = Array.from(new Set([...(keywords ?? []), ...SITE.keywords])).slice(0, 12);

const robots = noindex ? "noindex,follow" : "index,follow,max-image-preview:large";

// 全站统一注入 WebSite + Organization JSON-LD（含 SearchAction，便于 Google 显示站内搜索框）
const websiteSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${absoluteUrl("/")}#website`,
      url: absoluteUrl("/"),
      name: SITE.title,
      description: SITE.description,
      inLanguage: "zh-CN",
      publisher: { "@id": `${absoluteUrl("/")}#org` },
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: `${absoluteUrl("/reports")}?q={search_term_string}`,
        },
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "Organization",
      "@id": `${absoluteUrl("/")}#org`,
      name: SITE.title,
      url: absoluteUrl("/"),
      logo: absoluteUrl(SITE.defaultOgImage),
      sameAs: [SITE.repoUrl],
    },
  ],
};

const nav = [
  { href: `${base}/`, label: "首页", path: "/" },
  { href: `${base}/reports`, label: "全部报告", path: "/reports" },
  { href: `${base}/daily`, label: "AI 日报", path: "/daily" },
  { href: `${base}/tags`, label: "标签", path: "/tags" },
  { href: `${base}/trending`, label: "Trending", path: "/trending" },
  { href: `${base}/starred`, label: "大牛 Star", path: "/starred" },
  { href: `${base}/submit`, label: "提交仓库", path: "/submit" },
];
function isActive(p: string) {
  if (p === "/") return currentPath === "/" || currentPath === "";
  return currentPath.startsWith(p);
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta name="keywords" content={mergedKeywords.join(", ")} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#dc2626" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${base}/favicon.svg`} />

    {/* 站长平台验证（拿到 code 后填入 SITE.verify） */}
    {SITE.verify.google && <meta name="google-site-verification" content={SITE.verify.google} />}
    {SITE.verify.baidu && <meta name="baidu-site-verification" content={SITE.verify.baidu} />}
    {SITE.verify.bing && <meta name="msvalidate.01" content={SITE.verify.bing} />}

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImg} />
    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {ogType === "article" && articleTags?.map((t) => <meta property="article:tag" content={t} />)}

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImg} />

    {/* Feed 自动发现 */}
    <link rel="alternate" type="application/rss+xml" title={SITE.rssTitle} href={rssHref} />
    <link rel="alternate" type="application/feed+json" title={SITE.rssTitle} href={jsonFeedHref} />

    {/* 第三方资源预连接 */}
    <link rel="preconnect" href="https://opengraph.githubassets.com" crossorigin />
    <link rel="dns-prefetch" href="https://github.com" />

    {/* 站点级结构化数据 */}
    <JsonLd data={websiteSchema} />

    {/* 单页自定义 head：JSON-LD、preload 等 */}
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-zinc-200 bg-white sticky top-0 z-30 backdrop-blur">
      <div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap items-center gap-4">
        <a href={`${base}/`} class="flex items-center gap-2 font-semibold text-lg shrink-0">
          <span class="inline-block w-2 h-6 bg-brand rounded-sm"></span>
          <span>{SITE.title}</span>
        </a>
        <nav class="flex-1 flex flex-wrap items-center gap-1 text-sm">
          {
            nav.map((item) => (
              <a
                href={item.href}
                aria-current={isActive(item.path) ? "page" : undefined}
                class="px-3 py-1.5 rounded hover:bg-zinc-100 text-zinc-700 hover:text-zinc-900 aria-[current=page]:text-brand aria-[current=page]:font-medium"
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="order-last md:order-none w-full md:w-auto">
          <SearchBox size="sm" placeholder="搜索报告…" />
        </div>
        <a
          href={SITE.repoUrl}
          target="_blank"
          rel="noopener"
          class="text-sm text-zinc-500 hover:text-zinc-900 hidden md:inline"
          aria-label="GitHub 仓库"
        >
          GitHub →
        </a>
      </div>
    </header>

    <main class="flex-1" {...pagefindIgnore ? { "data-pagefind-ignore": "" } : {}}>
      <slot />
    </main>

    <footer class="mt-16 py-8 border-t border-zinc-200 text-sm text-zinc-500">
      <div class="max-w-6xl mx-auto px-4 flex flex-wrap gap-6 justify-between items-center">
        <div>
          © {new Date().getFullYear()} {SITE.title} · 由
          <a class="underline" href={SITE.repoUrl} target="_blank" rel="noopener"
            >AustinXT/github-explorer</a
          > 驱动
        </div>
        <div class="flex items-center gap-6">
          <div class="flex gap-4">
            <a class="hover:text-zinc-900" href={rssHref}>RSS</a>
            <a class="hover:text-zinc-900" href={`${base}/submit`}>提交一个仓库 →</a>
          </div>
          <WeChatFollow variant="footer" />
        </div>
      </div>
    </footer>
  </body>
</html>
